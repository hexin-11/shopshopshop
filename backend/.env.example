# 在这里填入您的火山引擎 (Ark) API Key (之前的已帮您移除，请去控制台重置并填入新的)
ARK_API_KEY=ark-1ea053ac-e70e-43bb-ba89-4ee55a46527f-d221e

# 这里请保持默认的 URL，不要改动
ARK_TEXT_MODEL_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/chat/completions
ARK_VIDEO_MODEL_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/contents/generations/tasks

# 这里填入您在火山引擎控制台为对应模型创建的推理接入点 (Endpoint ID，以 ep- 开头)
ARK_TEXT_MODEL_NAME=ep-20260609181740-kcnqb
ARK_VIDEO_MODEL_NAME=ep-20260609181905-xc2vh

# 注意：必须要将 MOCK 改为 false 才能真正调用大模型！如果是 true，后端只会返回假数据。
ARK_MOCK=false
