PORT=8787

# 当前默认使用 json，本地比赛演示无需数据库。
# 之后接数据库时改成 database，并在 storage/databaseAssetStore.js 实现具体逻辑。
ASSET_STORE=json

# 当前默认使用 json，本地比赛演示无需数据库。
# 之后接数据库时改成 database，并在 storage/databaseAppStore.js 实现具体逻辑。
APP_STORE=json

# Agent 会话当前使用 JSON 模拟数据库，数据文件是 backend/data/agentConversations.json。
# 之后接真实数据库时按 backend/database/schema.sql 建表，再改成 database。
AGENT_STORE=json

# 预留数据库连接配置，当前不会读取真实数据库。
DATABASE_URL=

# Agent 大模型接口。真实值只写到 backend/.env，不要提交到 GitHub。
# 兼容 OpenAI Chat Completions 的服务都可以接；豆包/火山方舟也按这个格式走。
AGENT_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
AGENT_API_KEY=
AGENT_MODEL=doubao-seed-1-6-lite
AGENT_TEMPERATURE=0.4

# 调试接口失败时才打开。正式演示建议保持 false，避免泄露上游返回细节。
AGENT_DEBUG=false
